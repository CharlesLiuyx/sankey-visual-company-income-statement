      "searchBox": {
        "x": 620,
        "y": 235,
        "width": 710,
        "height": 295
      },
      "threshold": 20,
      "foreground": {
        "any": [
          {
            "channels": {
              "r": [0, 50],
              "g": [0, 50],
              "b": [0, 50]
            }
          },
          {
            "channels": {
              "r": [180, 255],
              "g": [0, 80],
              "b": [0, 80]
            }
          }
        ]
      },
      "minComponentArea": 80,
      "padding": 18,
      "validation": {
        "borderBand": 5,
        "maxCenterOffset": 0.02,
        "maxForbiddenForegroundPixels": 0
      },
      "note": "Main Pinduoduo company logo and wordmark near the top center; excludes title, revenue label, chart links, and publisher marks."
    },
    {
      "key": "pdd-holdings-business-pinduoduo-app-icon",
