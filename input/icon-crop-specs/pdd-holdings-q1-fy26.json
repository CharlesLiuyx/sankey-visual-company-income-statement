{
  "source": "input/processed/pdd-holdings-q1-fy26.png",
  "outputDir": "data/assets/icon-references/pdd-holdings",
  "validationSheetDir": "data/assets/icon-references/pdd-holdings/validation-sheets",
  "report": "crop-report.json",
  "backgroundSampleBlocks": [
    [0, 0, 80, 80],
    [2587, 0, 80, 80],
    [0, 1420, 80, 80],
    [2587, 1420, 80, 80]
  ],
  "backgroundRemoval": {
    "enabled": true,
    "mode": "edge-connected",
    "tolerance": 8
