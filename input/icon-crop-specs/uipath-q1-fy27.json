{
  "source": "input/processed/uipath-q1-fy27.png",
  "outputDir": "data/assets/icon-references/uipath/crops",
  "validationSheetDir": "data/assets/icon-references/uipath/validation-sheets",
  "report": "../crop-report.json",
  "background": [242, 242, 242],
  "backgroundRemoval": {
    "enabled": true,
    "mode": "edge-connected",
    "tolerance": 8
  },
  "compression": {
    "enabled": true,
    "paletteColors": [256, 192, 128, 96, 64, 48, 32, 24],
    "maxMeanAbsoluteError": 1.2,
    "maxRootMeanSquareError": 3,
    "maxP99AbsoluteError": 12,
    "maxMaxChannelDiff": 72
  },
  "crops": [
    {
      "key": "uipath-company-wordmark",
      "output": "company-wordmark.png",
      "searchBox": { "x": 650, "y": 250, "width": 520, "height": 225 },
      "threshold": 22,
      "foreground": {
        "channels": {
          "r": [175, 255],
          "g": [35, 135],
          "b": [0, 95]
        }
      },
      "minComponentArea": 35,
      "padding": 26,
      "validation": {
        "borderBand": 3,
        "maxCenterOffset": 0.08,
        "maxForbiddenForegroundPixels": 0
      },
      "note": "UiPath company logo and wordmark near the top center; excludes chart nodes, flows, title, website URL, How They Make Money mark, and App Economy Insights attribution."
    }
  ]
}
